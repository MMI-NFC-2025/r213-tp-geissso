---
import { getOffres, getImageUrl } from '../backend.mjs';

const offres = await getOffres();
const offresAvecImages = offres.filter(offre => offre.images && offre.images.length > 0);


const imagesData = await Promise.all(
    offresAvecImages.map(async (offre) => ({
        url: await getImageUrl(offre, offre.images[0]),
        nom: offre.nomMaison,
        id: offre.id
    }))
);
---

<section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 opacity-10"></div>
    <div class="container mx-auto px-6 py-24 relative z-10">
        <div class="flex flex-col lg:flex-row items-center">
            <div class="lg:w-1/2 mb-12 lg:mb-0">
                <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight text-blue-800">
                    Trouvez Votre <span class="text-blue-800">Maison de Rêve</span>
                </h1>
                <p class="text-xl text-blue-800 mb-8 max-w-lg">
                    Découvrez notre sélection exclusive de propriétés avec l'aide de nos agents immobiliers experts.
                </p>
                <div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-4">
                    <a href="/offres" class="bg-blue-800 text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-900 transition-all transform hover:scale-105 shadow-lg text-center">
                        Voir les Offres
                    </a>
                    <a href="/agents" class="bg-blue-100 text-blue-800 px-8 py-4 rounded-xl font-bold hover:bg-blue-200 transition-all border border-blue-800 text-center">
                        Nos Agents
                    </a>
                </div>
            </div>
            <div class="lg:w-1/2 flex justify-center">
                <div class="relative w-full max-w-md">
                    <div class="absolute -top-10 -left-10 w-32 h-32 bg-cyan-500 rounded-full filter blur-3xl opacity-30 animate-pulse"></div>
                    <div class="absolute -bottom-10 -right-10 w-32 h-32 bg-blue-500 rounded-full filter blur-3xl opacity-30 animate-pulse"></div>
                    <div class="relative z-10 w-full rounded-2xl overflow-hidden shadow-2xl">
                        <div id="carousel" class="relative w-full h-[400px]">
                            {imagesData.map((image, index) => (
                                <div 
                                    class={`carousel-item absolute w-full h-full transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                                    data-index={index}
                                >
                                    <img 
                                        src={image.url} 
                                        alt={image.nom} 
                                        class="w-full h-full object-cover"
                                    />
                                    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-4"></div>
                                    </div>
                            ))}
                        </div>
                        
                        <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2 z-20">
                            {imagesData.map((_, index) => (
                                <button 
                                    class={`indicator w-2 h-2 rounded-full transition-all ${index === 0 ? 'bg-white w-8' : 'bg-white/50'}`}
                                    data-index={index}
                                    aria-label={`Aller à l'image ${index + 1}`}
                                ></button>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
</section>

<script>
    let currentIndex = 0;
    const items = document.querySelectorAll('.carousel-item');
    const indicators = document.querySelectorAll('.indicator');
    const totalItems = items.length;

    if (totalItems > 0) {
        function showSlide(index: number) {
            // Masquer toutes les images
            items.forEach((item) => {
                item.classList.remove('opacity-100');
                item.classList.add('opacity-0');
            });

            // Réinitialiser tous les indicateurs
            indicators.forEach((indicator) => {
                indicator.classList.remove('bg-white', 'w-8');
                indicator.classList.add('bg-white/50');
            });

            // Afficher l'image courante
            items[index].classList.remove('opacity-0');
            items[index].classList.add('opacity-100');

            // Activer l'indicateur courant
            indicators[index].classList.remove('bg-white/50');
            indicators[index].classList.add('bg-white', 'w-8');
        }

        function nextSlide() {
            currentIndex = (currentIndex + 1) % totalItems;
            showSlide(currentIndex);
        }

        setInterval(nextSlide, 4000);
        indicators.forEach((indicator, index) => {
            indicator.addEventListener('click', () => {
                currentIndex = index;
                showSlide(currentIndex);
            });
        });
    }
</script>
