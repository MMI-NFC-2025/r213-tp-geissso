---
const { agents } = Astro.props;
---

<article class=" ">
    <h2 class="text-2xl font-bold mb-4">Nos Agents</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {agents.map(agent => (
        <a href={`/agents/${agent.id}`} class="block bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow p-6">
            <h3 class="text-xl font-semibold mb-2">{agent.nom} {agent.prenom}</h3>
            <p class="text-gray-600">{agent.email}</p>
        </a>
        ))}
    </div>
</article>