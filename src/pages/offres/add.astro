---
import Layout from "../../layouts/Layout.astro";
import { addOffre } from "../../backend.mjs";

let pbMessage = "";
let success = false;

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    console.log(formData);
    
    // Validation des données
    const nomMaison = formData.get("nomMaison")?.toString() || "";
    const prix = parseFloat(formData.get("prix")?.toString() || "0");
    const surface = parseFloat(formData.get("surface")?.toString() || "0");
    
    if (!nomMaison) {
        pbMessage = "Le nom de la maison est obligatoire.";
    } else if (prix <= 0) {
        pbMessage = "Le prix doit être supérieur à 0.";
    } else if (surface && surface <= 0) {
        pbMessage = "La superficie doit être supérieure à 0.";
    } else {
        const result = await addOffre(formData);
        pbMessage = result.message;
        success = result.success;
    }
} else {
    console.log("GET request");
}
---
<Layout titre="Ajouter une offre">
<div class="mx-14 mt-10 border-2 border-blue-400 rounded-lg">
  <div class="mt-10 text-center font-bold">Immobilier</div>
  <div class="mt-3 text-center text-4xl font-bold">Ajouter une offre</div>
  {pbMessage && <div class="text-center mt-4"><p class={success ? 'text-green-600 font-semibold' : 'text-red-600 font-semibold'}>{pbMessage}</p></div>}
  <div class="p-8">
    <form action="/offres/add" method="POST" enctype="multipart/form-data">
      <div class="flex gap-4">
        <input type="text" name="nomMaison" placeholder="Nom de la maison *" required class="mt-1 block w-1/2 rounded-md border border-slate-300 bg-white px-3 py-4 shadow-sm placeholder:font-semibold placeholder:text-gray-500 focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 sm:text-sm" />
        <input type="number" name="prix" placeholder="Prix *" required min="0" step="0.01" class="mt-1 block w-1/2 rounded-md border border-slate-300 bg-white px-3 py-4 shadow-sm placeholder:font-semibold placeholder:text-gray-500 focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 sm:text-sm" />
      </div>
      <div class="my-6 flex gap-4">
        <input type="number" name="nbChambres" placeholder="Nombre de chambres" min="0" class="block w-1/2 rounded-md border border-slate-300 bg-white px-3 py-4 shadow-sm placeholder:font-semibold placeholder:text-gray-500 focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 sm:text-sm" />
        <input type="number" name="nbSdb" placeholder="Nombre de salles de bain" min="0" class="block w-1/2 rounded-md border border-slate-300 bg-white px-3 py-4 shadow-sm placeholder:font-semibold placeholder:text-gray-500 focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 sm:text-sm" />
      </div>
      <div class="my-6 flex gap-4">
        <input type="number" name="surface" placeholder="Superficie (m²)" min="0" step="0.01" class="block w-1/2 rounded-md border border-slate-300 bg-white px-3 py-4 shadow-sm placeholder:font-semibold placeholder:text-gray-500 focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 sm:text-sm" />
        <input type="text" name="adresse" placeholder="Adresse" class="block w-1/2 rounded-md border border-slate-300 bg-white px-3 py-4 shadow-sm placeholder:font-semibold placeholder:text-gray-500 focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 sm:text-sm" />
      </div>
      <div class="my-6">
        <input type="file" name="images" class="block w-full rounded-md border border-slate-300 bg-white px-3 py-4 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 sm:text-sm" />
      </div>
      <div class="text-center mb-6">
        <button type="submit" class="cursor-pointer rounded-lg bg-blue-700 px-8 py-5 text-sm font-semibold text-white hover:bg-blue-800 transition-colors">Ajouter l'offre</button>
      </div>
    </form>
  </div>
</div>
</Layout>