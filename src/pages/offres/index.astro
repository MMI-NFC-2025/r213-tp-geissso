---
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/Card.astro";
import { getOffres, filterByPrix } from '../../backend.mjs';
import PbImage from "../../components/PbImage.astro"
let offres = await getOffres();
let message = '';
if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const minPrixValue = data.get("minPrix");
    const maxPrixValue = data.get("maxPrix");
    const minPrix = minPrixValue ? parseInt(minPrixValue.toString()) : 0;
    const maxPrix = maxPrixValue ? parseInt(maxPrixValue.toString()) : 0;

    if (minPrix > 0 && maxPrix > 0 && maxPrix > minPrix) {
        offres = await filterByPrix(minPrix, maxPrix);
        if (offres.length === 0) {
            message = `Pas d'offres entre ${minPrix}€ et ${maxPrix}€`;
        } else {
            message = `Liste des offres entre ${minPrix}€ et ${maxPrix}€`;
        }
    } else {
        message = "Veuillez entrer des valeurs valides pour le prix.";
    }
} else {
    offres = await getOffres();
}
---
	<Layout titre="Accueil">
	<div class="container mx-auto px-4 mb-8">
		<div class="flex flex-wrap gap-4 mb-6 items-center justify-center">
			<button id="favori-button" class="px-6 py-3 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition shadow-md font-semibold">Afficher les favoris</button>
			<a href="/offres/surface/80" class="px-6 py-3 bg-green-500 text-white rounded-lg hover:bg-green-600 transition shadow-md font-semibold">
				Maisons + de 80m²
			</a>
			<a href="/offres/add" class="px-6 py-3 bg-purple-500 text-white rounded-lg hover:bg-purple-600 transition shadow-md font-semibold">
				Ajouter une offre
			</a>
		</div>
	</div>

	<div class="mx-14 mb-10 border-2 border-blue-400 rounded-lg shadow-lg">
		<div class="mt-6 text-center font-bold text-gray-700">Recherche</div>
		<div class="mt-2 text-center text-2xl font-bold text-gray-800">Filtrer par prix</div>
		{message && <div class="text-center mt-4"><p class={message.includes('Pas') || message.includes('Veuillez') ? 'text-red-600 font-semibold' : 'text-green-600 font-semibold'}>{message}</p></div>}
		<div class="p-8">
			<form action="/offres" method="POST">
				<div class="flex gap-4 items-end">
					<div class="flex-1">
						<label for="minPrix" class="block text-sm font-semibold text-gray-700 mb-2">Prix minimum (€)</label>
						<input type="number" name="minPrix" id="minPrix" placeholder="Ex: 100000" class="block w-full rounded-md border border-slate-300 bg-white px-4 py-4 shadow-sm placeholder:font-semibold placeholder:text-gray-400 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500 sm:text-sm" />
					</div>
					<div class="flex-1">
						<label for="maxPrix" class="block text-sm font-semibold text-gray-700 mb-2">Prix maximum (€)</label>
						<input type="number" name="maxPrix" id="maxPrix" placeholder="Ex: 500000" class="block w-full rounded-md border border-slate-300 bg-white px-4 py-4 shadow-sm placeholder:font-semibold placeholder:text-gray-400 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500 sm:text-sm" />
					</div>
					<button type="submit" class="px-8 py-4 bg-blue-700 text-white rounded-lg font-semibold hover:bg-blue-800 transition-colors shadow-md">
						Rechercher
					</button>
				</div>
			</form>
		</div>
	</div>

	<div class="container mx-auto px-4">
		<h2 class="text-2xl font-bold text-gray-800 mb-6">Nos offres</h2>
		<div class="grid gap-3">
			{offres.map((offre) => (
			<Card offre={offre} />
		))}
		</div>
	</div>
<script>
  const button = document.getElementById('favori-button');
  let showOnlyFavorites = false;

  button?.addEventListener('click', () => {
    showOnlyFavorites = !showOnlyFavorites;
    const offres : NodeListOf<HTMLElement> = document.querySelectorAll('.offre');

    offres.forEach(offre => {
      const isFavori = offre.dataset.favori === 'true';

      if (showOnlyFavorites) {
        offre.style.display = isFavori ? 'block' : 'none';
        button.textContent = 'Afficher tout';
      } else {
        offre.style.display = 'block';
        button.textContent = 'Afficher les favoris';
      }
    });
  });
</script>
</Layout>
	  